version: '3.8'

services:
  postgres:
    image: postgres:15-alpine
    container_name: soulcurator-postgres
    environment:
      POSTGRES_DB: soulcurator
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./init-db.sql:/docker-entrypoint-initdb.d/init-db.sql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - soulcurator-network

  redis:
    image: redis:7-alpine
    container_name: soulcurator-redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    command: redis-server --appendonly yes
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - soulcurator-network

  # backend:
  #   build: .
  #   container_name: soulcurator-backend
  #   depends_on:
  #     postgres:
  #       condition: service_healthy
  #     redis:
  #       condition: service_healthy
  #   environment:
  #     SPRING_PROFILES_ACTIVE: prod
  #     DB_URL: jdbc:postgresql://postgres:5432/soulcurator
  #     DB_USERNAME: postgres
  #     DB_PASSWORD: postgres
  #     REDIS_HOST: redis
  #     REDIS_PORT: 6379
  #   ports:
  #     - "8080:8080"
  #   volumes:
  #     - ./logs:/app/logs
  #   networks:
  #     - soulcurator-network
  #   restart: unless-stopped

volumes:
  postgres_data:
  redis_data:

networks:
  soulcurator-network:
    driver: bridge